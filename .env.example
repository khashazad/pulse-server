DATABASE_URL=postgresql://user:pass@db.example.supabase.co:5432/postgres
USDA_API_KEY=your-usda-fooddata-api-key
API_KEY=your-server-api-key
DEFAULT_USER_KEY=default
PORT=8787
TIMEZONE=America/Toronto

# MCP service-token auth (headless agents). Empty disables. Min 32 chars.
# Sent as `Authorization: Bearer <value>`. Synthesizes a `login=service-account`
# claim that the GitHub allowlist auto-includes.
MCP_SERVICE_TOKEN=
